# 1. Your Solana wallet private key. Must be a base58 string or a JSON byte array.
# Ensure this wallet is funded with both SOL (for gas/escrow) and USDC (for x402 payments).
SOLANA_PRIVATE_KEY=""

# 2. Synapse RPC URL. You can get a higher-tier key from OOBE Protocol if needed.
SYNAPSE_RPC_URL="https://api.mainnet-beta.solana.com"

# 3. How often the agent runs its workflow in milliseconds (120000 = 2 minutes)
WORKFLOW_INTERVAL_MS="120000"

# (Optional) Override the Synapse Sentinel wallet address or x402 endpoint
# SENTINEL_WALLET="Ccr2yK3hLALU4p8oNRqrh4dGuvPJTth5KCLMio8cE1ph"
# SENTINEL_ENDPOINT="https://sentinel.oobeprotocol.ai/x402"
